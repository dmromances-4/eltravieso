# Base de datos (PostgreSQL en producción y desarrollo)
# Local (docker-compose): postgresql://postgres:postgres@localhost:5432/vermut
# Supabase: usa la cadena de conexión de la base de datos (no la URL REST).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vermut"

# NextAuth
NEXTAUTH_SECRET="genera-un-secreto-largo-y-aleatorio"
NEXTAUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Bar Online — servidor de realtime independiente (npm run dev:ws)
# URL pública que usa el navegador para conectarse al servidor de sockets.
NEXT_PUBLIC_WS_URL="http://localhost:3001"
# Puerto en el que escucha el servidor de sockets (por defecto 3001).
WS_PORT=3001
# Redis para presencia/pub-sub entre instancias. Déjalo vacío para presencia
# en memoria (instancia única). Upstash: rediss://default:<token>@<host>:<port>
REDIS_URL=

# IA — al menos una clave de texto (gratis: Gemini o Groq)
# Prioridad por defecto: gemini → groq → openai → huggingface
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
HUGGINGFACE_API_KEY=
AI_PROVIDER=gemini
AI_IMAGE_PROVIDER=gemini

# Stripe / Holded (opcional para checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
HOLDED_API_KEY=
# Secreto HMAC para POST /api/integrations/holded/webhook (entrada desde Holded/Zapier)
HOLDED_WEBHOOK_SECRET=

# Square (sandbox por defecto; production para entorno real)
SQUARE_ENVIRONMENT=sandbox

# Rate limiting del agente IA (por IP anónima / por usuario autenticado)
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_ANON_MAX=10
AI_RATE_LIMIT_AUTH_MAX=30

# Shopify (OAuth + webhooks de catálogo)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Supabase Storage (opcional — solo subida de imágenes vía REST; auth = NextAuth)
# No uses Supabase Auth ni @supabase/ssr en este proyecto.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=tech-sheets
SUPABASE_AVATARS_BUCKET=avatars
SUPABASE_RECIPE_COVERS_BUCKET=recipe-covers
SUPABASE_RECIPE_VIDEOS_BUCKET=recipe-videos
# AI_MOCK=true genera portadas SVG de marca sin llamar a APIs de imagen
AI_MOCK=false
