# Base de datos (PostgreSQL)
# Perfil A — Docker Compose (docker compose up -d):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vermut"
# Perfil B — Embedded Postgres (npm run db:local):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/vermut"
# Supabase prod: usa la cadena de conexión de la base de datos (no la URL REST).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vermut"

# NextAuth — usa SIEMPRE http://localhost:3000 (no 127.0.0.1) en local
NEXTAUTH_SECRET="genera-un-secreto-largo-y-aleatorio"
NEXTAUTH_URL="http://localhost:3000"

# Admin — false = entrar a /admin sin 2FA (solo temporal; no usar en prod real)
ADMIN_REQUIRE_2FA=true

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Bar Online — servidor de realtime independiente (npm run dev:ws)
# URL pública que usa el navegador para conectarse al servidor de sockets.
NEXT_PUBLIC_WS_URL="http://localhost:3001"
# Puerto en el que escucha el servidor de sockets (por defecto 3001).
WS_PORT=3001
# Redis para presencia/pub-sub entre instancias. Déjalo vacío para presencia
# en memoria (instancia única). Upstash: rediss://default:<token>@<host>:<port>
REDIS_URL=

# IA — al menos una clave de texto (gratis: Gemini o Groq)
# Prioridad por defecto: gemini → groq → openai → huggingface
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=imagen-4.0-fast-generate-001
# Fallback si Imagen exige plan de pago: gemini-2.5-flash-image
GEMINI_FLASH_IMAGE_MODEL=gemini-2.5-flash-image
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
HUGGINGFACE_API_KEY=
AI_PROVIDER=gemini
AI_IMAGE_PROVIDER=gemini

# Stripe / Holded (opcional para checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_VIP_PRICE_ID=
STRIPE_MAP_FEATURED_PRICE_ID=
STRIPE_MAP_BOOKING_PRICE_ID=
MARKETPLACE_DEFAULT_COMMISSION_BPS=2000
VIP_MAX_ROOM_USERS=50
FREE_MAX_ROOM_USERS=10
VIP_DROP_AUTO_FULFILL=true
HOLDED_API_KEY=
# Secreto HMAC para POST /api/integrations/holded/webhook (entrada desde Holded/Zapier)
HOLDED_WEBHOOK_SECRET=

# Square (sandbox por defecto; production para entorno real)
SQUARE_ENVIRONMENT=sandbox

# Rate limiting del agente IA (por IP anónima / por usuario autenticado)
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_ANON_MAX=10
AI_RATE_LIMIT_AUTH_MAX=30

# Shopify (OAuth + webhooks de catálogo)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Campañas marketing (admin /admin/campaigns)
RESEND_API_KEY=
MARKETING_FROM_EMAIL=noreply@tudominio.com
MARKETING_UNSUBSCRIBE_SECRET=
MARKETING_MOCK=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Notion export (opcional — data source de Fichas Cócteles)
NOTION_DATA_SOURCE_ID=d8df242c-de72-49f9-83cd-e6383aaf503b

# Supabase Storage (opcional — solo subida de imágenes vía REST; auth = NextAuth)
# No uses Supabase Auth ni @supabase/ssr en este proyecto.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=tech-sheets
SUPABASE_AVATARS_BUCKET=avatars
SUPABASE_RECIPE_COVERS_BUCKET=recipe-covers
SUPABASE_RECIPE_VIDEOS_BUCKET=recipe-videos
SUPABASE_EVENT_VIDEOS_BUCKET=event-videos
SUPABASE_MEDIA_COVERS_BUCKET=media-covers

# Pantalla — TMDB + podcasts (/pantalla)
TMDB_API_KEY=
TMDB_API_BASE=https://api.themoviedb.org/3
# Cron Vercel: GET /api/cron/sync-podcasts con Authorization: Bearer <secret>
CRON_SECRET=
# AI_MOCK=true genera portadas SVG de marca sin llamar a APIs de imagen
AI_MOCK=false

# Portadas de recetas — stock gratuito + umbral de calidad (sin APIs de pago)
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
RECIPE_COVER_STOCK_MIN_SCORE=0.50
# Timeouts (ms) — evita cuelgues en Difford's, stock o descarga de imagen
RECIPE_COVER_FETCH_TIMEOUT_MS=15000
RECIPE_COVER_DIFFORDS_TIMEOUT_MS=20000
RECIPE_COVER_JOB_TIMEOUT_MS=90000
# Re-ranking opcional con Gemini vision (top 3 candidatos en zona gris 0.45–0.65)
RECIPE_COVER_VISION_RANK=false

# Sentry (observabilidad — opcional en local)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# CI / upload de source maps (Vercel)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Story Universe Engine — universo narrativo + cócteles
STORY_CORPUS_PATH=corpus/epubs
STORY_AI_THROTTLE_MS=1500
STORY_MIN_ORIGINALITY_SCORE=0.85
STORY_KNOWLEDGE_VERSION=1
