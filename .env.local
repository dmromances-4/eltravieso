# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="super-secret-key-please-change-in-production"

# Supabase PostgreSQL connection string (Update with your actual connection pooler URL)
# Example: postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://user:password@localhost:5432/mydb"

# Google Gemini API Key
GEMINI_API_KEY="your-gemini-api-key"

# OpenAI API Key (for DALL-E 3)
OPENAI_API_KEY="your-openai-api-key"

# Stripe (Ya configurado si lo tienes en el proyecto original, añade aquí si faltan)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
