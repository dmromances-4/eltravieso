// ─────────────────────────────────────────────────────────────────────────────
// Vermut El Travieso — Prisma Schema (Fase 1: Arquitectura Unificada B2B/B2C)
// Provider: PostgreSQL · All monetary values in Int (cents) · No floats.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ENUMS (PostgreSQL native)
// ═══════════════════════════════════════════════════════════════════════════════

enum UserRole {
  USER
  ADMIN
  BAR_OWNER
  WHOLESALER
}

enum MembershipStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum ProductSource {
  PROPIO
  MARKETPLACE
  AFILIADO
}

enum AffiliatePlatform {
  AMAZON
  TEMU
  ALIEXPRESS
  NONE
}

enum MapPlanTier {
  FREE
  FEATURED
  BOOKING_PLUS
}

enum ProductType {
  CONSUMABLE
  MERCH
  CONSERVA
}

enum ProductCategory {
  VERMUT
  COCTELERIA
  MERCH
  CONSERVA_LATERIO
  ALCOHOL
  SIROPE
  SODA
  CRISTALERIA
  MATERIAL
  ROPA
  INGREDIENTE
}

enum ReservationProvider {
  COVER_MANAGER
  THE_FORK
  SEVEN_ROOMS
  OPEN_TABLE
  EXTERNAL
}

enum Worlds50BestCategory {
  BARS
  RESTAURANTS
}

enum VenueSource {
  WORLDS_50_BEST
  MANUAL
}

enum VenueContinent {
  GLOBAL
  EUROPE
  ASIA
  NORTH_AMERICA
  LATIN_AMERICA
  MIDDLE_EAST_AFRICA
  OCEANIA
}

enum VenueListScope {
  GLOBAL
  REGIONAL
}

enum ProductFormat {
  BOTTLE_75CL
  BAG_IN_BOX_3L
  CASE_6
  CASE_12
  PALET
  UNIT
}

enum ProductChannel {
  B2C
  B2B
  BOTH
}

enum ListingStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum DropFulfillmentStatus {
  PENDING_PRODUCT
  PENDING_ADDRESS
  ORDER_CREATED
  FULFILLED
}

enum WholesaleOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  DISPATCHED
  INVOICED
  PAID
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum DeliveryRouteStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BatchStatus {
  IN_PRODUCTION
  QUALITY_CHECK
  AVAILABLE
  DEPLETED
  RECALLED
}

enum ForumTopicStatus {
  OPEN
  CLOSED
  PINNED
  ARCHIVED
}

enum BarOnlineSessionType {
  CHAT
  VIDEO_CALL
  TASTING_EVENT
}

enum CampaignChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

enum CampaignMessageStatus {
  QUEUED
  SENT
  FAILED
}

enum MediaKind {
  FILM
  SERIES
  SERIES_EPISODE
  PODCAST_SHOW
  PODCAST_EPISODE
  EVENT_VIDEO
}

enum MediaSourceType {
  EMBED
  UPLOAD
  EXTERNAL_URL
}

enum MediaPublishStatus {
  DRAFT
  PENDING
  PUBLISHED
  ARCHIVED
}

enum LiveCategory {
  GOLF
  SPORTS
  CULTURE
  OTHER
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUTH & USER
// ═══════════════════════════════════════════════════════════════════════════════

model User {
  id                 String    @id @default(uuid())
  name               String?
  email              String    @unique
  password           String
  imageUrl           String?
  birthDate          DateTime?
  ageVerifiedAt      DateTime? // AgeGate verification timestamp
  address            String?
  city               String?
  postalCode         String?
  country            String?   @default("España")
  phone              String?
  emailVerified      DateTime?
  role                 UserRole         @default(USER)
  twoFactorSecret      String?
  isTwoFactorEnabled   Boolean          @default(false)
  stripeCustomerId     String?          @unique
  stripeSubscriptionId String?          @unique
  membershipStatus     MembershipStatus @default(NONE)
  membershipExpiresAt  DateTime?
  preferredLocale      String           @default("es")
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  // Relations
  recipes           Recipe[]            @relation("AuthorRecipes")
  favoriteRecipes   Recipe[]            @relation("UserFavorites")
  posts             BlogPost[]
  accounts          Account[]
  sessions          Session[]
  orders            Order[]
  barProfile        BarProfile?
  forumTopics       ForumTopic[]
  forumComments     ForumComment[]
  barOnlineSessions BarOnlineSession[]  @relation("BarOnlineHost")
  barOnlineJoined   BarOnlineSession[]  @relation("BarOnlineParticipants")
  listings          Listing[]           @relation("UserListings")
  partnerProducts   Product[]           @relation("PartnerProducts")
  orderSplitLines   OrderSplitLine[]    @relation("PartnerSplitLines")
  dropFulfillments  MembershipDropFulfillment[]
  marketingConsent  MarketingConsent?
  campaignsCreated  Campaign[]          @relation("CampaignCreator")
  campaignMessages  CampaignMessage[]
  mediaItemsCreated MediaItem[]         @relation("MediaCreator")
  mediaComments     MediaComment[]
  mediaRatings      MediaRating[]
  liveStreamsCurated LiveStream[]       @relation("LiveStreamCurator")

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRODUCT CATALOG (B2C + B2B Unified)
// ═══════════════════════════════════════════════════════════════════════════════

model Product {
  id              String          @id @default(uuid())
  title           String
  slug            String          @unique
  description     String?         @db.Text
  type            ProductType     @default(CONSUMABLE)
  category        ProductCategory @default(VERMUT)
  channel         ProductChannel  @default(BOTH)
  imageUrl        String?
  galleryUrls     String[]        // PostgreSQL native array
  abv             Int?            // Alcohol percentage x100 (e.g. 1500 = 15.00%)
  volumeMl        Int?            // Volume in milliliters
  weightGrams     Int?            // Weight in grams (merch, conservas)
  isActive          Boolean         @default(true)
  source            ProductSource      @default(PROPIO)
  partnerId         String?
  commissionRateBps Int                @default(2000)
  affiliateUrl      String?
  affiliatePlatform AffiliatePlatform  @default(NONE)
  productCode       String?            @unique // ET-PROD-00001
  encyclopediaSlug  String?
  sourceUrl         String?
  metadata          Json?              // Flexible extra data (e.g. matchTerms: string[])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  variants         ProductVariant[]
  orderItems       OrderItem[]
  barStockEntries  BarStock[]
  taxRegistries    LiquorsTaxRegistry[]
  partner          User?            @relation("PartnerProducts", fields: [partnerId], references: [id])
  vipMonthlyDrops  VipMonthlyDrop[]

  @@index([slug])
  @@index([category, channel])
  @@index([type])
  @@index([source])
  @@index([partnerId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// MARKETPLACE — Listings subidos por usuarios (con aprobación admin)
// ═══════════════════════════════════════════════════════════════════════════════

model Listing {
  id               String          @id @default(uuid())
  sellerId         String
  title            String
  slug             String          @unique
  description      String?         @db.Text
  category         ProductCategory @default(MATERIAL)
  priceCents       Int
  imageUrl         String?
  format           ProductFormat   @default(UNIT)
  status           ListingStatus   @default(PENDING)
  reviewNotes      String?         @db.Text
  createdProductId String? // Product generado al aprobar
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  seller User @relation("UserListings", fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([status])
}

model ProductVariant {
  id              String         @id @default(uuid())
  productId       String
  sku             String         @unique
  format          ProductFormat
  channel         ProductChannel @default(BOTH)
  priceCents      Int            // Retail price in cents (B2C)
  wholesaleCents  Int?           // Wholesale price in cents (B2B)
  currency        String         @default("EUR")
  unitsPerCase    Int?           // Units per case (B2B packaging)
  casesPerPalet   Int?           // Cases per palet (B2B logistics)
  minOrderQty     Int            @default(1)
  stock           Int            @default(0)
  barcode         String?        // EAN-13
  stripeProductId String?
  stripePriceId   String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  product                Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems             OrderItem[]
  wholesaleOrderItems    WholesaleOrderItem[]
  vipMonthlyDrops        VipMonthlyDrop[]
  barStockEntries        BarStock[]

  @@index([productId])
  @@index([sku])
  @@index([format, channel])
}

// ═══════════════════════════════════════════════════════════════════════════════
// B2C ORDERS
// ═══════════════════════════════════════════════════════════════════════════════

model Order {
  id                String      @id @default(uuid())
  orderNumber       String      @unique // VT-2024-000001
  userId            String?
  guestEmail        String?
  status            OrderStatus @default(PENDING)
  subtotalCents     Int
  taxCents          Int
  shippingCents     Int         @default(0)
  totalCents        Int
  currency          String      @default("EUR")
  stripePaymentId   String?
  stripeSessionId   String?     @unique
  shippingAddress   Json?       // { street, city, postalCode, country }
  billingAddress    Json?
  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  user       User?            @relation(fields: [userId], references: [id])
  items      OrderItem[]
  splitLines OrderSplitLine[]

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@index([stripeSessionId])
}

model OrderItem {
  id              String  @id @default(uuid())
  orderId         String
  productId       String
  variantId       String?
  quantity        Int
  unitPriceCents  Int
  totalCents      Int

  // Relations
  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

model OrderSplitLine {
  id            String   @id @default(uuid())
  orderId       String
  orderItemId   String   @unique
  productId     String
  partnerId     String?
  grossCents    Int
  platformCents Int
  partnerCents  Int
  settled       Boolean  @default(false)
  createdAt     DateTime @default(now())

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  partner User? @relation("PartnerSplitLines", fields: [partnerId], references: [id])

  @@index([orderId])
  @@index([partnerId])
  @@index([settled])
}

model VipMonthlyDrop {
  id        String   @id @default(uuid())
  dropMonth String   @unique // e.g. "2026-06"
  productId String
  variantId String?
  label     String?
  createdAt DateTime @default(now())

  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([productId])
}

model MembershipDropFulfillment {
  id          String                @id @default(uuid())
  userId      String
  dropMonth   String                // e.g. "2026-06"
  productId   String?
  orderId     String?
  status      DropFulfillmentStatus @default(PENDING_PRODUCT)
  fulfilledAt DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dropMonth])
  @@index([userId])
  @@index([status])
  @@index([dropMonth])
}

// ═══════════════════════════════════════════════════════════════════════════════
// ERP HORECA — BAR PROFILE & STOCK
// ═══════════════════════════════════════════════════════════════════════════════

model BarProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique // Bar owner
  businessName         String
  taxId                String   @unique // CIF/NIF
  licenseNumber        String?           // Licencia de actividad
  googleBusinessId     String?
  tripadvisorPlaceId   String?
  venueCode            String?           @unique
  coverManagerUrl      String?           // iFrame URL
  theForkUrl           String?           // iFrame URL
  tpvProvider          String?           // "revo" | "lightspeed" | "square"
  tpvToken             String?           @db.Text
  tpvWebhookUrl        String?
  shopifyShopName      String?
  shopifyApiKey        String?           @db.Text
  shopifyAccessToken   String?           @db.Text
  shopifyScopes        String?
  shopifyLastSyncAt    DateTime?
  shopifySyncStatus    String?           // idle | syncing | ok | error
  shopifySyncError     String?           @db.Text
  holdedApiKey         String?           @db.Text
  holdedWebhookToken   String?           @db.Text
  holdedLastSyncAt     DateTime?
  holdedSyncStatus     String?
  holdedSyncError      String?           @db.Text
  squareAccessToken    String?           @db.Text
  squareLocationId     String?
  squareLastSyncAt     DateTime?
  squareSyncStatus     String?
  squareSyncError      String?           @db.Text
  latitude             Float?
  longitude            Float?
  venueType            String?           // cocteleria | restaurante | bar | bodega
  photoUrl             String?
  isPublicOnMap        Boolean     @default(false)
  mapPlan              MapPlanTier @default(FREE)
  mapPlanExpiresAt     DateTime?
  stripeSubscriptionId String?     @unique
  isPremium            Boolean     @default(false)
  bookingWidgetEnabled Boolean     @default(false)
  slug                 String?     @unique
  history              String?  @db.Text
  foundationYear       Int?
  signatureDrink       String?
  dressCode            String?
  vibeTags             String[]
  establishmentTypes   String[] @default([])
  cuisineTypes         String[] @default([])
  starDishes           String[] @default([])
  idealFor             String[] @default([])
  venueFeatures        String[] @default([])
  neighborhood         String?
  priceRange           String?
  dailyMenuEnabled     Boolean  @default(false)
  dailyMenuNote        String?
  awards               String[] @default([])
  venuePreferences     String[] @default([])
  instagramUrl         String?
  tiktokUrl            String?
  tripadvisorUrl       String?
  verdict              String?  @db.Text
  reservationProvider  ReservationProvider?
  reservationUrl       String?
  address              String
  city                 String
  postalCode           String
  province             String?
  country              String   @default("España")
  phone                String?
  email                String?
  autoReorderEnabled   Boolean  @default(false)
  autoReorderThreshold Int?     // Min units before trigger
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stockEntries      BarStock[]
  wholesaleOrders   WholesaleOrder[]
  deliveryStops     DeliveryStop[]
  guideEntry        VenueGuideEntry?
  mediaEvents       MediaItem[]

  @@index([taxId])
  @@index([city])
}

model VenueGuideEntry {
  id                   String               @id @default(uuid())
  slug                 String               @unique
  name                 String
  city                 String
  country              String?
  address              String?
  venueType            String
  photoUrl             String?
  history              String?              @db.Text
  verdict              String?              @db.Text
  chefName             String?
  worlds50bestRank     Int
  worlds50bestCategory Worlds50BestCategory
  worlds50bestYear     Int?
  continent            VenueContinent?
  listScope            VenueListScope       @default(GLOBAL)
  regionalRank         Int?
  additionalRankings   Json?
  sourceUrl            String               @unique
  externalWebsite      String?
  googleBusinessId     String?
  tripadvisorUrl       String?
  tripadvisorPlaceId   String?
  tripadvisorRating    Float?
  establishmentTypes   String[]             @default([])
  cuisineTypes         String[]             @default([])
  starDishes           String[]             @default([])
  idealFor             String[]             @default([])
  venueFeatures        String[]             @default([])
  neighborhood         String?
  priceRange           String?
  dailyMenuEnabled     Boolean              @default(false)
  dailyMenuNote        String?
  awards               String[]             @default([])
  venuePreferences     String[]             @default([])
  instagramUrl         String?
  tiktokUrl            String?
  venueCode            String?              @unique
  enrichmentSource     String?
  latitude             Float?
  longitude            Float?
  geocodeConfidence    String?
  isPublished          Boolean              @default(true)
  barProfileId         String?              @unique
  source               VenueSource          @default(WORLDS_50_BEST)
  scrapedAt            DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  barProfile BarProfile? @relation(fields: [barProfileId], references: [id])

  @@index([worlds50bestCategory, worlds50bestRank])
  @@index([city])
}

model BarStock {
  id              String   @id @default(uuid())
  barProfileId    String
  productId       String
  variantId       String?
  currentUnits    Int      @default(0)
  minThreshold    Int      @default(0) // Auto-reorder trigger
  maxCapacity     Int?
  lastSyncedAt    DateTime? // Last TPV webhook sync
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  barProfile BarProfile      @relation(fields: [barProfileId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id])
  variant    ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([barProfileId, productId, variantId])
  @@index([barProfileId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// ERP HORECA — WHOLESALE ORDERS & INVOICING
// ═══════════════════════════════════════════════════════════════════════════════

model WholesaleOrder {
  id                  String               @id @default(uuid())
  orderNumber         String               @unique // WS-2024-000001
  barProfileId        String
  status              WholesaleOrderStatus  @default(DRAFT)
  subtotalCents       Int
  exciseTaxCents      Int                   // Impuestos Especiales (8%) — cents
  vatCents            Int                   // IVA (21%) — cents
  totalCents          Int
  currency            String                @default("EUR")
  notes               String?               @db.Text
  requestedDeliveryAt DateTime?
  approvedAt          DateTime?
  dispatchedAt        DateTime?
  deliveryRouteId     String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  // Relations
  barProfile    BarProfile           @relation(fields: [barProfileId], references: [id])
  items         WholesaleOrderItem[]
  invoice       WholesaleInvoice?
  deliveryRoute DeliveryRoute?       @relation("RouteOrders", fields: [deliveryRouteId], references: [id])

  @@index([barProfileId])
  @@index([status])
  @@index([orderNumber])
  @@index([deliveryRouteId])
}

model WholesaleOrderItem {
  id                String  @id @default(uuid())
  wholesaleOrderId  String
  variantId         String
  batchId           String? // FIFO dispatch from ProductionBatch
  quantity          Int
  unitPriceCents    Int
  totalCents        Int

  // Relations
  wholesaleOrder WholesaleOrder  @relation(fields: [wholesaleOrderId], references: [id], onDelete: Cascade)
  variant        ProductVariant  @relation(fields: [variantId], references: [id])
  batch          ProductionBatch? @relation(fields: [batchId], references: [id])

  @@index([wholesaleOrderId])
  @@index([batchId])
}

model WholesaleInvoice {
  id                 String        @id @default(uuid())
  invoiceNumber      String        @unique // FV-2024-000001
  wholesaleOrderId   String        @unique
  status             InvoiceStatus @default(DRAFT)
  issuedAt           DateTime      @default(now())
  dueAt              DateTime
  subtotalCents      Int
  exciseTaxCents     Int
  vatCents           Int
  totalCents         Int
  currency           String        @default("EUR")
  pdfUrl             String?
  ticketBaiId        String?       // TicketBAI / Veri*factu reference
  notes              String?       @db.Text
  paidAt             DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Relations
  wholesaleOrder WholesaleOrder @relation(fields: [wholesaleOrderId], references: [id])

  @@index([status])
  @@index([invoiceNumber])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PRODUCTION & TRACEABILITY
// ═══════════════════════════════════════════════════════════════════════════════

model ProductionBatch {
  id              String      @id @default(uuid())
  batchCode       String      @unique // LOT-2024-A001
  productId       String?
  status          BatchStatus @default(IN_PRODUCTION)
  totalUnits      Int
  remainingUnits  Int
  bottlingDate    DateTime?
  expiryDate      DateTime?
  abv             Int?        // Actual ABV x100
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  wholesaleOrderItems WholesaleOrderItem[]
  taxRegistries       LiquorsTaxRegistry[]

  @@index([batchCode])
  @@index([status])
}

model LiquorsTaxRegistry {
  id              String   @id @default(uuid())
  productId       String
  batchId         String?
  caeCode         String   // Código de Actividad del Establecimiento
  sealNumber      String?  // Precinta fiscal number
  exciseTaxCents  Int      // Tax amount in cents
  taxRateBps      Int      @default(800) // 8% = 800 basis points
  declaredLiters  Int      // Liters x100 for precision (e.g. 7500 = 75.00L)
  declaredAbv     Int      // ABV x100
  declarationDate DateTime
  fiscalPeriod    String   // "2024-Q1"
  documentRef     String?  // AEAT reference
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  // Relations
  product Product          @relation(fields: [productId], references: [id])
  batch   ProductionBatch? @relation(fields: [batchId], references: [id])

  @@index([caeCode])
  @@index([productId])
  @@index([fiscalPeriod])
}

// ═══════════════════════════════════════════════════════════════════════════════
// DELIVERY & LOGISTICS
// ═══════════════════════════════════════════════════════════════════════════════

model DeliveryRoute {
  id          String              @id @default(uuid())
  routeCode   String              @unique // RT-2024-BCN-001
  status      DeliveryRouteStatus @default(PLANNED)
  driverId    String?
  vehiclePlate String?
  plannedDate DateTime
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?             @db.Text
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // Relations
  stops  DeliveryStop[]
  orders WholesaleOrder[] @relation("RouteOrders")

  @@index([status])
  @@index([plannedDate])
}

model DeliveryStop {
  id              String   @id @default(uuid())
  deliveryRouteId String
  barProfileId    String
  stopOrder       Int      // Sequence in route
  estimatedArrival DateTime?
  actualArrival    DateTime?
  signature        String?  // Base64 signature on delivery
  notes            String?
  createdAt        DateTime @default(now())

  // Relations
  deliveryRoute DeliveryRoute @relation(fields: [deliveryRouteId], references: [id], onDelete: Cascade)
  barProfile    BarProfile    @relation(fields: [barProfileId], references: [id])

  @@index([deliveryRouteId])
  @@index([barProfileId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// RECIPES & TECHNICAL SHEETS
// ═══════════════════════════════════════════════════════════════════════════════

model Recipe {
  id          String          @id @default(uuid())
  title       String
  slug        String          @unique
  summary     String?         @db.Text
  glass       String?
  ingredients String          @db.Text
  method      String?         @db.Text
  imageUrl    String?
  videoUrl    String?
  difficulty  Int?            @default(1) // 1-5
  prepTimeMins Int?
  servings    Int?
  tags        String[]        // PostgreSQL native array
  isPublished Boolean         @default(true)
  isPremium   Boolean         @default(false)
  authorId    String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  author      User            @relation(fields: [authorId], references: [id], name: "AuthorRecipes")
  favoritedBy User[]          @relation("UserFavorites")
  technical   TechnicalSheet?
  translations RecipeTranslation[]

  @@index([slug])
  @@index([authorId])
}

model TechnicalSheet {
  id          String   @id @default(uuid())
  recipeId    String   @unique
  costCents   Int?
  abv         Int?     // ABV x100 (e.g. 1200 = 12.00%)
  tasting     String?  @db.Text
  imageUrl    String?
  pdfUrl      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model RecipeTranslation {
  id          String   @id @default(uuid())
  recipeId    String
  locale      String
  title       String
  summary     String?  @db.Text
  glass       String?
  ingredients String   @db.Text
  method      String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, locale])
  @@index([locale])
}

// ═══════════════════════════════════════════════════════════════════════════════
// STORY UNIVERSE — Cocktail narrative franchise
// ═══════════════════════════════════════════════════════════════════════════════

enum StoryStatus {
  DRAFT
  QC_PASSED
  QC_FAILED
  APPROVED
  SCRIPTED
  STORYBOARDED
  READY
}

model CocktailNarrativeProfile {
  id               String   @id @default(cuid())
  cocktailSlug     String   @unique
  cocktailTitle    String
  aromaticProfile  String[]
  tasteProfile     String[]
  color            String   @db.Text
  intensity        Int      @default(3)
  personality      String[]
  symbolism        String[]
  evokedSensations String[]
  narrativeHooks   String[]
  originHint       String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  stories Story[]

  @@index([cocktailSlug])
}

model Story {
  id                 String       @id @default(cuid())
  storyId            String       @unique
  title              String
  logline            String       @db.Text
  theme              String
  subthemes          String[]
  cocktailSlug       String
  emotionProfile     Json
  characterList      Json
  locations          Json
  conflict           Json
  resolution         Json
  visualIdentity     Json
  animationPotential Float        @default(0.7)
  categoryId         String
  status             StoryStatus  @default(DRAFT)
  qcScore            Float?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  cocktailProfile CocktailNarrativeProfile @relation(fields: [cocktailSlug], references: [cocktailSlug])
  script          StoryScript?
  storyboard      StoryStoryboard?
  animationPrompts StoryAnimationPrompt[]

  @@index([cocktailSlug])
  @@index([categoryId])
  @@index([status])
}

model StoryScript {
  id                   String   @id @default(cuid())
  storyId              String   @unique
  synopsis             String   @db.Text
  treatment            String   @db.Text
  screenplay           Json
  estimatedRuntimeMins Int
  wordCount            Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model StoryStoryboard {
  id        String   @id @default(cuid())
  storyId   String   @unique
  scenes    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model StoryAnimationPrompt {
  id          String   @id @default(cuid())
  storyId     String
  sceneNumber Int
  prompts     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, sceneNumber])
  @@index([storyId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// COMMUNITY — BLOG, FORUM, BAR ONLINE
// ═══════════════════════════════════════════════════════════════════════════════

model BlogPost {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  content     String    @db.Text
  excerpt     String?   @db.Text
  coverUrl    String?
  tags        String[]
  published   Boolean   @default(false)
  isPremium   Boolean   @default(false)
  publishedAt DateTime?
  locale      String    @default("es")
  metadata    Json?
  authorId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  author User? @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([published])
  @@index([authorId])
  @@index([isPremium])
}

model ForumTopic {
  id          String           @id @default(uuid())
  title       String
  slug        String           @unique
  content     String           @db.Text
  status      ForumTopicStatus @default(OPEN)
  isPinned    Boolean          @default(false)
  viewCount   Int              @default(0)
  authorId    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relations
  author   User           @relation(fields: [authorId], references: [id])
  comments ForumComment[]

  @@index([slug])
  @@index([status])
  @@index([authorId])
}

model ForumComment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  topicId   String
  authorId  String
  parentId  String?  // Nested replies
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  topic    ForumTopic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author   User          @relation(fields: [authorId], references: [id])
  parent   ForumComment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies  ForumComment[] @relation("CommentReplies")

  @@index([topicId])
  @@index([authorId])
  @@index([parentId])
}

model BarOnlineSession {
  id           String                @id @default(uuid())
  title        String
  description  String?               @db.Text
  type         BarOnlineSessionType  @default(CHAT)
  hostId       String
  maxUsers     Int                   @default(10)
  isPrivate    Boolean               @default(false)
  hdEnabled    Boolean               @default(false)
  isActive     Boolean               @default(true)
  scheduledAt  DateTime?
  startedAt    DateTime?
  endedAt      DateTime?
  roomId       String?               @unique // WebSocket/WebRTC room identifier
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  // Relations
  host         User   @relation("BarOnlineHost", fields: [hostId], references: [id])
  participants User[] @relation("BarOnlineParticipants")

  @@index([hostId])
  @@index([isActive])
  @@index([type])
}

// ═══════════════════════════════════════════════════════════════════════════════
// WEBHOOK IDEMPOTENCY
// ═══════════════════════════════════════════════════════════════════════════════

model ProcessedWebhook {
  id        String   @id @default(uuid())
  eventId   String   @unique
  source    String
  createdAt DateTime @default(now())

  @@index([source])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PLATFORM AUDIT LOG
// ═══════════════════════════════════════════════════════════════════════════════

model AuditLog {
  id           String   @id @default(cuid())
  action       String
  actorId      String?
  actorEmail   String?
  resourceType String?
  resourceId   String?
  requestId    String?
  ip           String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([requestId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// MARKETING CAMPAIGNS
// ═══════════════════════════════════════════════════════════════════════════════

model MarketingConsent {
  userId        String    @id
  emailOptIn    Boolean   @default(false)
  smsOptIn      Boolean   @default(false)
  whatsappOptIn Boolean   @default(false)
  consentedAt   DateTime?
  consentSource String?
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Campaign {
  id          String          @id @default(uuid())
  name        String
  channel     CampaignChannel
  status      CampaignStatus  @default(DRAFT)
  subject     String?
  bodyHtml    String?         @db.Text
  bodyText    String          @db.Text
  audience    Json            @default("{}")
  scheduledAt DateTime?
  sentAt      DateTime?
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  createdBy User              @relation("CampaignCreator", fields: [createdById], references: [id])
  messages  CampaignMessage[]

  @@index([status])
  @@index([channel])
  @@index([createdById])
}

model CampaignMessage {
  id         String                @id @default(uuid())
  campaignId String
  recipient  String
  userId     String?
  status     CampaignMessageStatus @default(QUEUED)
  providerId String?
  error      String?               @db.Text
  sentAt     DateTime?
  createdAt  DateTime              @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([userId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PANTALLA — MEDIA CATALOG
// ═══════════════════════════════════════════════════════════════════════════════

model MediaItem {
  id            String             @id @default(uuid())
  title         String
  slug          String             @unique
  kind          MediaKind
  summary       String?            @db.Text
  coverUrl      String?
  mediaUrl      String?
  playbackUrl   String?
  sourceType    MediaSourceType    @default(EMBED)
  parentId      String?
  seasonNumber  Int?
  episodeNumber Int?
  eventDate     DateTime?
  cocktailSlugs String[]           @default([])
  tags          String[]           @default([])
  status        MediaPublishStatus @default(DRAFT)
  publishedAt   DateTime?
  barProfileId  String?
  createdById   String
  tmdbId        Int?
  tmdbType      String?
  imdbId        String?
  releaseYear   Int?
  runtimeMins   Int?
  metadata      Json?
  episodeGuid   String?
  ratingAvg     Float              @default(0)
  ratingCount   Int                @default(0)
  commentCount  Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  parent     MediaItem?    @relation("MediaEpisodes", fields: [parentId], references: [id], onDelete: Cascade)
  episodes   MediaItem[]   @relation("MediaEpisodes")
  barProfile BarProfile?   @relation(fields: [barProfileId], references: [id], onDelete: SetNull)
  createdBy  User          @relation("MediaCreator", fields: [createdById], references: [id])
  podcastFeed PodcastFeed?
  comments   MediaComment[]
  ratings    MediaRating[]

  @@index([kind])
  @@index([status])
  @@index([slug])
  @@index([parentId])
  @@index([barProfileId])
  @@index([createdById])
  @@index([tmdbId])
  @@index([episodeGuid])
}

model PodcastFeed {
  id           String    @id @default(uuid())
  title        String
  rssUrl       String    @unique
  coverUrl     String?
  mediaItemId  String    @unique
  lastSyncedAt DateTime?
  syncEnabled  Boolean   @default(true)
  lastError    String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  show MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
}

model LiveStream {
  id              String             @id @default(uuid())
  title           String
  slug            String             @unique
  category        LiveCategory       @default(OTHER)
  embedUrl        String
  backupEmbedUrl  String?
  isLive          Boolean            @default(true)
  scheduledStart  DateTime?
  scheduledEnd    DateTime?
  coverUrl        String?
  summary         String?            @db.Text
  status          MediaPublishStatus @default(DRAFT)
  curatedById     String
  sourceLabel     String?
  lastCheckedAt   DateTime?
  lastCheckOk     Boolean?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  curatedBy User @relation("LiveStreamCurator", fields: [curatedById], references: [id])

  @@index([status])
  @@index([category])
  @@index([isLive])
  @@index([slug])
}

model MediaComment {
  id          String   @id @default(uuid())
  mediaItemId String
  authorId    String
  content     String   @db.Text
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mediaItem MediaItem      @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  author    User           @relation(fields: [authorId], references: [id])
  parent    MediaComment?  @relation("MediaCommentReplies", fields: [parentId], references: [id])
  replies   MediaComment[] @relation("MediaCommentReplies")

  @@index([mediaItemId])
  @@index([authorId])
  @@index([parentId])
}

model MediaRating {
  id          String   @id @default(uuid())
  mediaItemId String
  userId      String
  score       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mediaItem MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mediaItemId, userId])
  @@index([mediaItemId])
  @@index([userId])
}
